# kith-pms production environment
# Copy to .env and fill in values before running docker compose up.

# ── Required ──────────────────────────────────────────────────────────────────

# At least 32 random bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Bcrypt hash of your login password. Set with: ./kith-pms set-password
APP_PASSWORD_HASH=

# ── Optional ──────────────────────────────────────────────────────────────────

# Bearer token for API clients (leave empty to disable token auth)
TOKEN_AUTH=

# Sentry DSN for error monitoring
SENTRY_DSN=

# Set to true if kith is behind a TLS-terminating reverse proxy (enables Secure cookie flag)
BEHIND_TLS=false

# Session lifetime (default 30 days)
SESSION_LIFETIME=720h

# Bind address for the host port mapping (default: 127.0.0.1 — loopback only)
BIND_ADDR=127.0.0.1

# Port on the host to map to container port 8000
PORT=8000

# Enable verbose debug logging
DEBUG=false
