// DateRow renders a blank date input row for htmx "Add date" insertion.
templ DateRow(index int) {
	<tr>
		<td class="pr-2 pb-1">
			<select
				name={ forms.IndexedName("date", index, "kind") }
				class="w-full border border-sage-border rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-deep-olive"
			>
				<option value="birthday">Birthday</option>
				<option value="anniversary">Anniversary</option>
				<option value="met">Met</option>
				<option value="other">Other</option>
			</select>
		</td>
		<td class="pr-2 pb-1">
			<input
				type="text"
				name={ forms.IndexedName("date", index, "label") }
				placeholder="Label"
				class="w-full border border-sage-border rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-deep-olive"
			/>
		</td>
		<td class="pr-2 pb-1">
			<input
				type="text"
				name={ forms.IndexedName("date", index, "date_value") }
				placeholder="YYYY-MM-DD or --MM-DD"
				class="w-full border border-sage-border rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-deep-olive"
			/>
		</td>
		<td class="pr-2 pb-1">
			<input
				type="checkbox"
				name={ forms.IndexedName("date", index, "recurring") }
				value="1"
				checked
				class="border border-sage-border rounded focus:outline-none focus:ring-1 focus:ring-deep-olive"
			/>
		</td>
		<td class="pb-1">
			<input
				type="text"
				name={ forms.IndexedName("date", index, "notes") }
				placeholder="Notes (optional)"
				class="w-full border border-sage-border rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-deep-olive"
			/>
		</td>
	</tr>
}

